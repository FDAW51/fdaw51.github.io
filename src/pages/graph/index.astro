---
import GridLayout from "@layouts/grid.astro";
---

<GridLayout title="知识图谱" description="Eugene 的知识图谱——基于 Wiki 的交互式力导向图" lang="zh-CN">
  <div class="card-base p-4 mb-4">
    <div class="flex flex-wrap items-center gap-3 mb-4 text-sm">
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full inline-block" style="background:#D4A017"></span> 实体</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full inline-block" style="background:#4A90D9"></span> 概念</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full inline-block" style="background:#2ECC71"></span> 主题</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full inline-block" style="background:#E67E22"></span> 摘要</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full inline-block" style="background:#9B59B6"></span> 综合</span>
      <span class="ml-2 text-black/40 dark:text-white/40">| 滚轮缩放 · 拖拽节点探索知识关联</span>
    </div>
    <div id="graph-container" class="w-full rounded-lg overflow-hidden" style="height:70vh;min-height:500px;background:var(--card-bg)">
      <div id="graph-loading" class="flex items-center justify-center h-full text-black/40 dark:text-white/40">
        <span>加载知识图谱中...</span>
      </div>
    </div>
  </div>
</GridLayout>

<script>
  import * as echarts from 'echarts';

  let chartInstance = null;
  let resizeHandler = null;
  let themeObserver = null;
  let swupCleanupRegistered = false;
  let isInitialized = false;

  function disposeChart() {
    isInitialized = false;
    if (themeObserver) { themeObserver.disconnect(); themeObserver = null; }
    if (resizeHandler) { window.removeEventListener('resize', resizeHandler); resizeHandler = null; }
    if (chartInstance) { chartInstance.dispose(); chartInstance = null; }
  }

  function getThemeColors() {
    const isDark = document.documentElement.classList.contains('dark');
    const style = getComputedStyle(document.documentElement);
    const lineDivider = style.getPropertyValue('--line-divider').trim();
    return {
      textColor: isDark ? 'rgba(255,255,255,0.6)' : 'rgba(0,0,0,0.5)',
      edgeColor: lineDivider || (isDark ? '#334155' : '#d1d5db'),
    };
  }

  async function initGraph() {
    if (isInitialized) return;
    isInitialized = true;

    const container = document.getElementById('graph-container');
    if (!container) {
      isInitialized = false;
      return;
    }

    // 注册 Swup 离开页面时自动清理
    if (!swupCleanupRegistered) {
      const register = () => {
        if (window.swup?.hooks) {
          window.swup.hooks.on('content:replace', disposeChart, { before: true });
          swupCleanupRegistered = true;
        }
      };
      if (window.swup?.hooks) { register(); }
      else { document.addEventListener('swup:enable', register, { once: true }); }
    }

    try {
      const resp = await fetch('/data/graph-data.json');
      const graphData = await resp.json();

      document.getElementById('graph-loading')?.remove();

      // --- 构建 ECharts categories（基于数据动态生成） ---
      const categoryMap = new Map();
      graphData.nodes.forEach(n => {
        if (!categoryMap.has(n.group)) {
          categoryMap.set(n.group, { name: n.group, itemStyle: { color: n.color } });
        }
      });
      const categories = Array.from(categoryMap.values());
      const groupToIdx = Object.fromEntries(categories.map((c, i) => [c.name, i]));

      const colors = getThemeColors();

      // --- 初始化 ECharts ---
      chartInstance = echarts.init(container, null, { renderer: 'canvas' });

      // 类型名中文映射
      const groupNameCN = {
        entity: '实体', concept: '概念', topic: '主题',
        summary: '摘要', synthesis: '综合', meta: '元',
      };

      const option = {
        backgroundColor: 'transparent',
        legend: { show: false },

        tooltip: {
          trigger: 'item',
          formatter: (params) => {
            if (params.dataType === 'node') {
              const group = params.data.categoryName || '';
              const cn = groupNameCN[group] || group;
              return `<strong style="font-size:14px">${params.name}</strong><br/>
                      <span style="color:${params.color}">●</span> ${cn}`;
            }
            return '';
          },
        },

        series: [{
          type: 'graph',
          layout: 'force',

          // 交互
          roam: true,
          draggable: true,

          // 节点数据
          data: graphData.nodes.map(n => ({
            id: n.id,
            name: n.label,
            category: groupToIdx[n.group],
            categoryName: n.group,
            itemStyle: { color: n.color },
          })),

          // 边数据
          links: graphData.edges.map(e => ({
            source: e.from,
            target: e.to,
          })),

          categories,

          // 力导向参数
          force: {
            repulsion: 600,
            edgeLength: [80, 200],
            gravity: 0.05,
            friction: 0.15,
            layoutAnimation: false,
          },

          edgeSymbol: ['none', 'none'],
          edgeLabel: { show: false },

          // 节点标签
          label: {
            show: true,
            position: 'right',
            color: colors.textColor,
            fontSize: 10,
            opacity: 0.7,
          },

          // 边样式
          lineStyle: {
            color: colors.edgeColor,
            width: 0.8,
            opacity: 0.25,
            curveness: 0.15,
          },

          // 节点大小
          symbolSize: 8,

          // 高亮效果（悬停时关联节点置灰，关联边高亮）
          emphasis: {
            focus: 'adjacency',
            lineStyle: {
              width: 2.5,
              opacity: 0.9,
            },
            label: {
              fontWeight: 'bold',
              opacity: 1,
              fontSize: 12,
            },
          },

          blur: {
            opacity: 0.15,
            lineStyle: { opacity: 0.05 },
          },

          // 入场动画
          animationDuration: 600,
          animationEasingUpdate: 'cubicOut',
        }],
      };

      chartInstance.setOption(option);

      // --- 窗口 resize ---
      resizeHandler = () => chartInstance?.resize();
      window.addEventListener('resize', resizeHandler);

      // --- 监听深色/浅色模式切换 ---
      themeObserver = new MutationObserver(() => {
        if (!chartInstance) return;
        const c = getThemeColors();
        chartInstance.setOption({
          series: [{
            label: { color: c.textColor },
            lineStyle: { color: c.edgeColor },
          }],
        });
      });
      themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
      });
    } catch (err) {
      console.error('Failed to load graph data:', err);
      const loading = document.getElementById('graph-loading');
      if (loading) loading.textContent = '图谱数据加载失败';
      isInitialized = false;
    }
  }

  document.addEventListener('DOMContentLoaded', initGraph);
  document.addEventListener('twilight:page:loaded', initGraph);
</script>
